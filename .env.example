# Copy to .env on the machine that runs the jobs.
# Do not commit real secrets.

BDP_DB_HOST=
BDP_DB_PORT=3306
BDP_DB_NAME=
BDP_DB_USER=
BDP_DB_PASSWORD=

# QNH login states. Use separate accounts when running dimensions in parallel.
QNH_ACTIVITY_ET=
QNH_STORE_ET=

# Internal signing service used to generate mtgsig.
QNH_MTGSIG_SERVICE_URL=

